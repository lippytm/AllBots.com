# 🤖 MARVIN DCA BOT — Configuration
# Copy this to .env and fill in your values

# Exchange Settings
EXCHANGE=binance          # binance, coinbase, kraken
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Trading Settings
TRADING_PAIR=BTC/USDT     # BTC/USDT, ETH/USDT, SOL/USDT
BUY_AMOUNT=50             # USD amount per DCA purchase
INTERVAL_HOURS=72         # How often to buy (72 = every 3 days)

# Safety — ALWAYS start in paper trading mode!
PAPER_TRADING=true        # Set to false only when ready for live trading

# Telegram Alerts (optional but recommended)
TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# OpenRouter multi-model routing (optional)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_APP_URL=https://allbots.com
OPENROUTER_APP_NAME=AllBots.com
OPENROUTER_DEFAULT_MODEL=openai/gpt-4.1-mini
OPENROUTER_CODING_MODEL=anthropic/claude-3.7-sonnet
OPENROUTER_RESEARCH_MODEL=google/gemini-2.5-pro
OPENROUTER_CREATIVE_MODEL=anthropic/claude-3.7-sonnet
OPENROUTER_CHEAP_MODEL=openai/gpt-4.1-mini
OPENROUTER_VISION_MODEL=openai/gpt-4.1
